{
  "name": "@xpr-lang/xpr",
  "description": "Sandboxed cross-language expression language for data pipeline transforms",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && tsc --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "yaml": "^2.0.0"
  },
  "author": "XPR Lang",
  "homepage": "https://github.com/xpr-lang/xpr-js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpr-lang/xpr-js.git"
  },
  "keywords": ["expression", "language", "sandbox", "transform", "pipeline", "xpr"]
}
